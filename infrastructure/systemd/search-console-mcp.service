[Unit]
Description=Search Console MCP Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ads-mcp
ExecStart=/opt/ads-mcp/.venv/bin/python servers/search-console/main.py
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
