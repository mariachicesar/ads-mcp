[Unit]
Description=Search Console MCP Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/ads-mcp
ExecStart=/opt/ads-mcp/.venv/bin/python servers/search-console/main.py
Restart=always
RestartSec=5
StandardOutput=append:/var/log/ads-mcp/search-console.log
StandardError=append:/var/log/ads-mcp/search-console.log
Environment=PYTHONUNBUFFERED=1
Environment=AWS_REGION=us-east-1
Environment=ADS_MCP_REQUIRE_SIGNED_REQUESTS=true

[Install]
WantedBy=multi-user.target
